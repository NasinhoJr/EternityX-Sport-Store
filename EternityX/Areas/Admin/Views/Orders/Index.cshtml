@model IEnumerable<EternityX.Models.Order>

@{
    ViewData["Title"] = "Поръчки";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🧾 Управление на поръчки</h4>
          
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Потребител</th>
                        <th>Дата</th>
                        <th>Обща сума</th>
                        <th>Име</th>
                        <th>Адрес</th>
                        <th>Град</th>
                        <th>Област</th>
                        <th>Пощенски код</th>
                        <th style="width:230px">Действия</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ApplicationUser.UserName</td>
                            <td>@item.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.OrderTotal.ToString("0.00") €</td>
                            <td>@item.Name</td>
                            <td>@item.StreetAddress</td>
                            <td>@item.City</td>
                            <td>@item.State</td>
                            <td>@item.PostalCode</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">🔍</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-3">Няма намерени поръчки.</div>
            }
        </div>
    </div>
</div>