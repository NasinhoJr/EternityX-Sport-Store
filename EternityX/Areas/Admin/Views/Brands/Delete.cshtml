@model EternityX.Models.Brand
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Изтриване на бранд";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 col-md-6 mx-auto">
        <div class="card-header bg-danger text-white">
            <h4>🗑 Изтриване на бранд</h4>
        </div>

        <div class="card-body">
            <p class="text-danger fw-semibold">
                Сигурни ли сте, че искате да изтриете този бранд?
            </p>

            <dl class="row">
                <dt class="col-sm-4">Име</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Държава</dt>
                <dd class="col-sm-8">@Model.Country</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">⬅ Отказ</a>
                    <button type="submit" class="btn btn-danger">Изтрий</button>
                </div>
            </form>
        </div>
    </div>
</div>
