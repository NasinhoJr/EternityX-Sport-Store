@model IEnumerable<EternityX.Models.Product>
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Продукти";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🛍 Управление на продукти</h4>
            <a asp-area="Admin" asp-controller="Products" asp-action="Create"
               class="btn btn-success btn-sm">➕ Добави продукт</a>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Снимка</th>
                        <th>Име</th>
                        <th>Цена</th>
                        <th>Наличност</th>
                        <th>Категория</th>
                        <th>Бранд</th>
                        <th style="width:220px">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>
                                @{
                                    string imgSrc =
                                    string.IsNullOrWhiteSpace(p.Picture)
                                    ? "https://via.placeholder.com/80"
                                    : (p.Picture.StartsWith("http")
                                    ? p.Picture
                                    : Url.Content($"~/images/products/{p.Picture}"));
                                }

                                <img src="@imgSrc"
                                     width="70" height="70"
                                     class="rounded shadow"
                                     style="object-fit:cover"
                                     onerror="this.src='https://via.placeholder.com/80';" />
                        </td>
                        <td class="fw-semibold">@p.Name</td>
                        <td>@p.Price.ToString("0.00") €</td>
                        <td>@p.Stock</td>
                        <td>@p.Category?.Name</td>
                        <td>@p.Brand?.Name</td>
                        <td>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit"
                               asp-route-id="@p.Id"
                               class="btn btn-warning btn-sm">✏️</a>

                                <a asp-area="Admin" asp-controller="Products" asp-action="Details"
                                   asp-route-id="@p.Id"
                                   class="btn btn-info btn-sm text-white">🔍</a>

                                <a asp-area="Admin" asp-controller="Products" asp-action="Delete"
                                   asp-route-id="@p.Id"
                                   class="btn btn-danger btn-sm">🗑</a>
                            </td>
                        </tr>
                                        }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-3">
                    Няма добавени продукти.
                </div>
            }
        </div>
    </div>
</div>
