@model EternityX.Models.Product
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Редакция на продукт";
}

@{
    // ✅ Ако Picture е URL -> директно
    // ✅ Ако Picture е име на файл -> от wwwroot/images/products/
    string displayImg =
        string.IsNullOrWhiteSpace(Model.Picture)
            ? "https://placehold.co/200x200"
            : (Model.Picture.StartsWith("http")
                ? Model.Picture
                : Url.Content($"~/images/products/{Model.Picture}"));
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 col-lg-8 mx-auto">
        <div class="card-header bg-warning">
            <h4>✏️ Редакция на продукт</h4>
        </div>

        <div class="card-body">
            <form asp-area="Admin"
                  asp-controller="Products"
                  asp-action="Edit"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div class="text-center mb-3">
                    <img src="@displayImg"
                         width="150"
                         class="rounded shadow"
                         onerror="this.src='https://placehold.co/200x200';" />
                </div>

                <!-- ✅ URL -->
                <div class="mb-3">
                    <label asp-for="PictureUrl">URL на снимка</label>
                    <input asp-for="PictureUrl"
                           class="form-control"
                           placeholder="https://..." />
                    <span asp-validation-for="PictureUrl" class="text-danger"></span>
                </div>

                <!-- ✅ File upload -->
                <div class="mb-3">
                    <label asp-for="PictureFile">Качи нова снимка (файл)</label>
                    <input asp-for="PictureFile" type="file" class="form-control" />
                    <span asp-validation-for="PictureFile" class="text-danger"></span>
                    <small class="text-muted">Ако качиш файл, той заменя текущата снимка.</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name">Име</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price">Цена</label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description">Описание</label>
                    <textarea asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Stock">Наличност</label>
                        <input asp-for="Stock" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Color">Цвят</label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Категория</label>
                        <select asp-for="CategoryId"
                                asp-items="ViewBag.CategoryId"
                                class="form-select"></select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Бранд</label>
                        <select asp-for="BrandId"
                                asp-items="ViewBag.BrandId"
                                class="form-select"></select>
                        <span asp-validation-for="BrandId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-area="Admin"
                       asp-controller="Products"
                       asp-action="Index"
                       class="btn btn-secondary">⬅ Назад</a>

                    <button type="submit" class="btn btn-warning">
                        Запази
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>