@model IEnumerable<EternityX.Models.OrderItem>

@{
    ViewData["Title"] = "Order Items";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">📦 Order Items</h4>
            <a asp-action="Create" class="btn btn-success btn-sm">➕ Add Item</a>
        </div>

        <div class="card-body">
            <table class="table table-hover text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th style="width:230px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.Order.Id</td>
                            <td class="fw-semibold">@item.Product.Name</td>
                            <td>@item.Count</td>
                            <td>@item.Price.ToString("0.00") €</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏️</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">🔍</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-3">No order items found.</div>
            }
        </div>
    </div>
</div>
