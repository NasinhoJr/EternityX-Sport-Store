@model IEnumerable<EternityX.Models.Brand>

@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Брандове";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🏷️ Управление на брандове</h4>
            <a asp-action="Create" class="btn btn-success btn-sm">➕ Добави бранд</a>
        </div>

        <div class="card-body">
            <table class="table table-hover text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Име</th>
                        <th>Държава</th>
                        <th style="width:230px">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Country</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏️</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">🔍</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-muted text-center py-3">
                    Няма намерени брандове.
                </div>
            }
        </div>
    </div>
</div>
