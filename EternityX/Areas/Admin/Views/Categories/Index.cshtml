@model IEnumerable<EternityX.Models.Category>
@section Styles {
    <link rel="stylesheet" href="~/css/admin.css" />
}
@{
    ViewData["Title"] = "Категории";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">📂 Управление на категории</h4>
            <a asp-action="Create" class="btn btn-success btn-sm">
                ➕ Добави категория
            </a>
        </div>

        <div class="card-body">
            <table class="table table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 25%">Име</th>
                        <th>Описание</th>
                        <th style="width: 230px">Действия</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-muted">@item.Description</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm me-1">
                                    ✏️
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm text-white me-1">
                                    🔍
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    🗑
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-3">
                    Няма намерени категории.
                </div>
            }
        </div>
    </div>
</div>
