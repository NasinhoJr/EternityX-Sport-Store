@model EternityX.Models.ApplicationUser

@{
    ViewData["Title"] = "Нов потребител";
}

<h2 class="mb-3">Нов потребител</h2>

<form method="post">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Име</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label">Имейл</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label">Потребителско име</label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label">Телефон</label>
            <input asp-for="PhoneNumber" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Адрес</label>
            <input asp-for="StreetAddress" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Град</label>
            <input asp-for="City" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Област</label>
            <input asp-for="State" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Пощенски код</label>
            <input asp-for="PostalCode" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Парола</label>
            <input name="password" type="password" class="form-control" />
            <span class="text-danger">@Html.ValidationMessage("Password")</span>
        </div>
    </div>

    <div class="mt-4">
        <button class="btn btn-success">Създай</button>
        <a class="btn btn-secondary" asp-action="Index">Назад</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
