@model EternityX.Models.OrderItem

@{
    ViewData["Title"] = "Create Order Item";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 col-md-6 mx-auto">
        <div class="card-header bg-success text-white">
            <h4>➕ Create Order Item</h4>
        </div>

        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="OrderId" class="form-label fw-semibold"></label>
                    <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderId"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductId" class="form-label fw-semibold"></label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="Count" class="form-label fw-semibold"></label>
                    <input asp-for="Count" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <input asp-for="Price" class="form-control" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
